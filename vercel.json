{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/people.js": { "maxDuration": 30 },
    "api/edges.js": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=120, stale-while-revalidate=60" }
      ]
    }
  ]
}
